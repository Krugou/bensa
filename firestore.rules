rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow public read access to stations and price history
    match /stations/{station} {
      allow read: if true;
      allow write: if false; // Bot uses Admin SDK which bypasses rules
    }
    
    match /price_history/{history} {
      allow read: if true;
      allow write: if false;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
